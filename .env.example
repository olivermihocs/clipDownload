# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real credentials.

# From https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# Your Twitch username (broadcaster login name, lowercase)
TWITCH_BROADCASTER_NAME=your_twitch_username

# Folder where clips will be saved (created automatically)
OUTPUT_DIR=clips

# Only download clips with at least this many views (0 = download all)
MIN_VIEWS=0

# Only download clips where this keyword appears in the title or creator name (leave empty to download all)
KEYWORD=
